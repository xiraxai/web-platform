# Copy a .env.local para desarrollo. NUNCA commitear .env.local.

# Resend API (cuando migremos form de mailto a email transaccional)
# RESEND_API_KEY=re_xxx
# RESEND_FROM=contacto@xiraxai.com
# RESEND_TO=raphael@xiraxai.com

# ── FASE 3: Blog automático (Make.com → /api/blog/publish) ──────────────────
# Secret HMAC para autenticar llamadas de Make.com al webhook del blog
# Generar: openssl rand -hex 32
# BLOG_WEBHOOK_SECRET=

# Deploy Hook de Vercel (para triggear rebuild cuando se publica un post)
# Obtener en: Vercel → Project web-platform → Settings → Git → Deploy Hooks
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/xxx

# GitHub API (para crear archivos .md en el repo desde el webhook serverless)
# Token: GitHub → Settings → Developer settings → Personal access tokens
# Permisos necesarios: repo (read + write)
# GITHUB_TOKEN=ghp_xxx
# GITHUB_REPO=xiraxai/web-platform
# GITHUB_BRANCH=main

# Analytics (futuro)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Error tracking (futuro)
# SENTRY_DSN=
